  ################################################################################
# FILAMENT LOADING & UNLOADING SYSTEM - SOVOL SV08 4-TOOL CONFIGURATION
################################################################################
#
# PURPOSE:
# Provides safe, consistent filament loading and unloading for 4-tool 
# toolchanger configurations. All parameters are easily adjustable at the top.
#
# FEATURES:
# - All settings configurable via variables at the top of each macro
# - Automatic temperature management
# - Safe toolhead positioning for easy filament access
# - Single tool or batch operations for all tools
# - Temperature safety overrides when needed
#
# USAGE GUIDE:
# - LOAD_FILAMENT: Load filament into currently active tool
# - LOAD_FILAMENT TEMP=220: Load with custom temperature
# - UNLOAD_FILAMENT: Unload filament from currently active tool
# - UNLOAD_ONE_FILAMENT TOOL=1: Unload specific tool by number (0-3)
# - UNLOAD_ALL_FILAMENT: Unload all 4 tools sequentially (batch operation)
#
# CONFIGURATION:
# Edit the variable_* settings in each macro to customize behavior
#
################################################################################


################################################################################
# SINGLE TOOL OPERATIONS
################################################################################

[gcode_macro LOAD_FILAMENT]
description: Load filament into currently active tool
# Allow extrusion below minimum temp (for maintenance/testing)
variable_ignore_min_extrude_temp: True

# ============ CONFIGURABLE PARAMETERS ============
variable_load_temp: 240              # Loading temperature (°C)
variable_extrude_length: 50          # Extrusion length per pass (mm)
variable_extrude_speed: 300          # Extrusion speed (mm/min)
variable_retract_length: 4           # Final retraction to prevent ooze (mm)
variable_retract_speed: 1800         # Retraction speed (mm/min)
variable_num_extrude_passes: 2       # Number of extrusion passes
variable_turn_off_heater: True       # Turn off heater when done

gcode:
  # Get parameters (allow temperature override)
  {% set TEMP = params.TEMP|default(load_temp)|float %}
  
  # ==========================================================================
  # ===== LOADING SEQUENCE =====
  # ==========================================================================
  M117 Loading Filament
  RESPOND TYPE=echo MSG="Starting filament load sequence"
  
  # Start heating immediately (non-blocking)
  M104 S{TEMP}
  
  # Move toolhead to convenient loading position
  RESPOND TYPE=echo MSG="Moving to loading position"
  MOVE_TO_LOAD
  
  # Wait for target temperature
  RESPOND TYPE=echo MSG="Heating to {TEMP}°C for loading"
  M104 S{TEMP}
  TEMPERATURE_WAIT SENSOR={printer.toolhead.extruder} MINIMUM={TEMP}
  
  # Extrude filament in multiple passes
  M83  # Relative extrusion mode
  {% for pass in range(num_extrude_passes) %}
    RESPOND TYPE=echo MSG="Extruding {extrude_length}mm (pass {pass + 1}/{num_extrude_passes})"
    G1 E{extrude_length} F{extrude_speed}
  {% endfor %}
  
  # Small retraction to prevent oozing
  RESPOND TYPE=echo MSG="Retracting {retract_length}mm to prevent ooze"
  G1 E-{retract_length} F{retract_speed}
  
  # Reset to absolute mode and finish
  M82  # Absolute extrusion mode
  M400 # Wait for all moves to complete
  
  # Turn off heater if configured
  {% if turn_off_heater %}
    M104 S0
    RESPOND TYPE=echo MSG="Heater turned off"
  {% else %}
    RESPOND TYPE=echo MSG="Heater left on for convenience"
  {% endif %}
  
  M117 Loading Complete
  RESPOND TYPE=echo MSG="Filament loading complete"


[gcode_macro MOVE_TO_LOAD]
description: Moves toolhead to loading position (changes based on print state)
# ============ CONFIGURABLE PARAMETERS ============
variable_load_x_idle: 175            # X position when not printing
variable_load_y_idle: 175             # Y position when not printing
variable_load_z_idle: 50             # Z position when not printing
variable_load_x_printing: 175        # X position during print/pause
variable_load_y_printing: 350        # Y position during print/pause
variable_travel_speed: 1800          # Movement speed (mm/min)

gcode:
  ## Save current gcode offsets to preserve tool offsets
  {% set saved_offset_x = printer.gcode_move.homing_origin.x %}
  {% set saved_offset_y = printer.gcode_move.homing_origin.y %}
  {% set saved_offset_z = printer.gcode_move.homing_origin.z %}
  
  SAVE_GCODE_STATE NAME=BEFORE_MOVE_TO_LOAD
  
  # Home if needed
  {% if "xyz" not in printer.toolhead.homed_axes %}
    G28
  {% endif %}
  
  G90  # Absolute positioning mode
  {% if not (printer.print_stats.state == "paused" or printer.idle_timeout.state == "Printing") %}
    # Not printing - move to front load position
    G1 Z{load_z_idle} F{travel_speed}
    G1 X{load_x_idle} Y{load_y_idle} F{travel_speed}
  {% else %} 
    # Printing or paused - move to safe load position
    G1 X{load_x_printing} Y{load_y_printing} F{travel_speed}
  {% endif %}
  
  RESTORE_GCODE_STATE NAME=BEFORE_MOVE_TO_LOAD
  
  ## Re-apply tool offsets that were wiped by RESTORE_GCODE_STATE
  SET_GCODE_OFFSET X={saved_offset_x} Y={saved_offset_y} Z={saved_offset_z} MOVE=0


[gcode_macro UNLOAD_FILAMENT]
description: Unload filament from currently active tool
# Allow extrusion below minimum temp (for maintenance/testing)
variable_ignore_min_extrude_temp: True

# ============ CONFIGURABLE PARAMETERS ============
variable_unload_temp: 240            # Unloading temperature (°C)
variable_prime_length: 5             # Initial extrude to ensure melt (mm)
variable_prime_speed: 500            # Prime extrusion speed (mm/min)
variable_retract_length: 50          # Retraction length per pass (mm)
variable_retract_speed: 1000         # Retraction speed (mm/min)
variable_num_retract_passes: 2       # Number of retraction passes
variable_turn_off_heater: True       # Turn off heater when done

gcode:
  # Get parameters (allow temperature override)
  {% set TEMP = params.TEMP|default(unload_temp)|float %}
  
  # ==========================================================================
  # ===== UNLOADING SEQUENCE =====
  # ==========================================================================
  M117 Unloading Filament
  RESPOND TYPE=echo MSG="Starting filament unload sequence"
  
  # Heat nozzle for clean filament removal
  RESPOND TYPE=echo MSG="Heating to {TEMP}°C for unloading"
  M104 S{TEMP}
  TEMPERATURE_WAIT SENSOR={printer.toolhead.extruder} MINIMUM={TEMP}
  
  # Small extrusion to ensure filament tip is melted
  M83  # Relative extrusion mode
  RESPOND TYPE=echo MSG="Priming {prime_length}mm to ensure melt"
  G1 E{prime_length} F{prime_speed}
  
  # Retract filament in multiple passes
  {% for pass in range(num_retract_passes) %}
    RESPOND TYPE=echo MSG="Retracting {retract_length}mm (pass {pass + 1}/{num_retract_passes})"
    G1 E-{retract_length} F{retract_speed}
  {% endfor %}
  
  # Reset to absolute mode and finish
  M82  # Absolute extrusion mode
  M400 # Wait for all moves to complete
  
  # Turn off heater when done
  {% if turn_off_heater %}
    M104 S0
    RESPOND TYPE=echo MSG="Heater turned off"
  {% else %}
    RESPOND TYPE=echo MSG="Heater left on for convenience"
  {% endif %}
  
  M117 Unloading Complete
  RESPOND TYPE=echo MSG="Filament unloading complete - remove filament now"


################################################################################
# MULTI-TOOL OPERATIONS (FOR 4-TOOL CONFIGURATION)
################################################################################

[gcode_macro UNLOAD_ONE_FILAMENT]
description: Unload filament from a specific tool (TOOL=0/1/2/3)

# ============ CONFIGURABLE PARAMETERS ============
variable_unload_temp: 240            # Unloading temperature (°C)
variable_prime_length: 5             # Initial extrude to ensure melt (mm)
variable_prime_speed: 500            # Prime extrusion speed (mm/min)
variable_retract_length: 50          # Retraction length per pass (mm)
variable_retract_speed: 1000         # Retraction speed (mm/min)
variable_num_retract_passes: 2       # Number of retraction passes
variable_turn_off_heater: True       # Turn off heater when done

gcode:
  # ==========================================================================
  # ===== PARAMETER VALIDATION =====
  # ==========================================================================
  {% if 'TOOL' not in params %}
    RESPOND TYPE=error MSG="TOOL parameter required! Usage: UNLOAD_ONE_FILAMENT TOOL=0"
    M117 Error: Missing TOOL
    {% else %}
  
  {% set TOOL_NUM = params.TOOL|int %}
  {% set TEMP = params.TEMP|default(unload_temp)|float %}
  
  # Validate tool number (0-3 for 4-tool system)
  {% if TOOL_NUM < 0 or TOOL_NUM >= printer.toolchanger.tool_names|length %}
    RESPOND TYPE=error MSG="Invalid tool number! Must be 0-{printer.toolchanger.tool_names|length - 1}"
    M117 Error: Invalid Tool
  {% else %}

  # ==========================================================================
  # ===== TOOL IDENTIFICATION =====
  # ==========================================================================
  {% set tool_name = printer.toolchanger.tool_names[TOOL_NUM] %}
  {% set extruder = printer[tool_name].extruder %}

  # ==========================================================================
  # ===== UNLOADING SEQUENCE =====
  # ==========================================================================
  M117 Unloading T{TOOL_NUM}
  RESPOND TYPE=echo MSG="Unloading filament from Tool {TOOL_NUM} ({tool_name})"
  
  # Heat and wait (blocking) - using M109 for safety
  RESPOND TYPE=echo MSG="Heating T{TOOL_NUM} to {TEMP}°C"
  M104 T{TOOL_NUM} S{TEMP}
  TEMPERATURE_WAIT SENSOR={extruder} MINIMUM={TEMP}
  
  # Activate the correct extruder
  ACTIVATE_EXTRUDER EXTRUDER={extruder}
  
  # Small extrusion to ensure filament tip is melted
  M83  # Relative extrusion mode
  RESPOND TYPE=echo MSG="Priming {prime_length}mm"
  G1 E{prime_length} F{prime_speed}
  
  # Retract filament in multiple passes
  {% for pass in range(num_retract_passes) %}
    RESPOND TYPE=echo MSG="Retracting {retract_length}mm (pass {pass + 1}/{num_retract_passes})"
    G1 E-{retract_length} F{retract_speed}
  {% endfor %}
  
  # Reset to absolute mode and finish
  M82  # Absolute extrusion mode
  M400 # Wait for all moves to complete
  
  # Turn off heater if configured
  {% if turn_off_heater %}
    M104 T{TOOL_NUM} S0
    RESPOND TYPE=echo MSG="T{TOOL_NUM} heater turned off"
  {% endif %}
  
  M117 T{TOOL_NUM} Unload Complete
  RESPOND TYPE=echo MSG="Tool {TOOL_NUM} unloading complete"
  
  {% endif %}
  {% endif %}



# ==========================================================================
# ===== LOADING SEQUENCE =====
# ==========================================================================

[gcode_macro LOAD_ONE_FILAMENT]
