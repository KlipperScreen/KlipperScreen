[gcode_macro UNLOAD_ALL_FILAMENT]
description: Unload filament from all 4 tools sequentially (batch operation)

# ============ CONFIGURABLE PARAMETERS ============
variable_unload_temp: 250            # Unloading temperature (°C)
variable_prime_length: 5             # Initial extrude to ensure melt (mm)
variable_prime_speed: 500            # Prime extrusion speed (mm/min)
variable_retract_length: 50          # Retraction length per pass (mm)
variable_retract_speed: 1000         # Retraction speed (mm/min)
variable_num_retract_passes: 2       # Number of retraction passes
variable_preheat_all_tools: True     # Heat all tools before starting
variable_turn_off_heaters: True      # Turn off all heaters when done

gcode:
  # Get parameters
  {% set TEMP = params.TEMP|default(unload_temp)|float %}
  
  # Get list of all available tools
  {% set tools = printer.toolchanger.tool_names %}
  {% set tool_count = tools|length %}

  # ==========================================================================
  # ===== BATCH UNLOAD SEQUENCE =====
  # ==========================================================================
  M117 Unloading All {tool_count} Tools
  RESPOND TYPE=echo MSG="Starting batch unload for {tool_count} tools"
  
  # ===== PHASE 1: START HEATING ALL TOOLS (if enabled) =====
  {% if preheat_all_tools %}
    RESPOND TYPE=echo MSG="Phase 1: Pre-heating all tools to save time"
    {% for tool in tools %}
      {% set tool_num = printer[tool].tool_number %}
      M104 T{tool_num} S{TEMP}
      RESPOND TYPE=echo MSG="Started heating T{tool_num}"
    {% endfor %}
  {% endif %}
  
  # ===== PHASE 2: UNLOAD EACH TOOL =====
  RESPOND TYPE=echo MSG="Phase 2: Unloading each tool sequentially"
  {% for tool in tools %}
    {% set tool_num = printer[tool].tool_number %}
    {% set extruder = printer[tool].extruder %}
    
    M117 Unloading T{tool_num}
    
    # Wait for this tool to reach temperature
    {% if not preheat_all_tools %}
      M104 T{tool_num} S{TEMP}
    {% endif %}
    RESPOND TYPE=echo MSG="Waiting for T{tool_num} to reach {TEMP}°C"
    TEMPERATURE_WAIT SENSOR={extruder} MINIMUM={TEMP}
    
    # Activate this tool's extruder
    ACTIVATE_EXTRUDER EXTRUDER={extruder}
    
    # Unload sequence for this tool
    M83  # Relative extrusion mode
    RESPOND TYPE=echo MSG="T{tool_num}: Priming {prime_length}mm"
    G1 E{prime_length} F{prime_speed}
    
    {% for pass in range(num_retract_passes) %}
      RESPOND TYPE=echo MSG="T{tool_num}: Retracting {retract_length}mm ({pass + 1}/{num_retract_passes})"
      G1 E-{retract_length} F{retract_speed}
    {% endfor %}
    
    RESPOND TYPE=echo MSG="T{tool_num}: Unload complete"
  {% endfor %}
  
  # ===== PHASE 3: CLEANUP =====
  M400 # Wait for all moves to complete
  M82  # Return to absolute extrusion mode
  
  {% if turn_off_heaters %}
    TURN_OFF_HEATERS
    RESPOND TYPE=echo MSG="All heaters turned off"
  {% endif %}
  
  M117 All {tool_count} Tools Unloaded
  RESPOND TYPE=echo MSG="Batch unload complete - all {tool_count} tools ready"


